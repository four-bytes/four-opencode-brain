{
  "name": "@four-bytes/four-opencode-brain",
  "version": "1.6.1",
  "description": "Unified brain plugin — single SQLite DB for RAG search, memory, and knowledge base",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production bun run scripts/build.ts",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "four-bytes"
  ],
  "dependencies": {
    "@four-bytes/opencode-plugin-lib": "github:four-bytes/four-opencode-plugin-lib#v0.2.0",
    "@opencode-ai/plugin": "1.16.2",
    "@opentui/core": "0.3.2",
    "@opentui/solid": "0.3.2",
    "node-llama-cpp": "3.18.1",
    "solid-js": "1.9.13",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-php": "0.24.2",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-typescript": "0.23.2",
    "web-tree-sitter": "0.26.9"
  },
  "devDependencies": {
    "bun-types": "1.3.14"
  },
  "exports": {
    "./server": {
      "types": "./dist/four-opencode-brain.d.ts",
      "import": "./dist/four-opencode-brain.js"
    },
    "./tui": {
      "types": "./dist/four-opencode-brain-tui.d.ts",
      "import": "./dist/four-opencode-brain-tui.jsx"
    }
  }
}
