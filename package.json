{
  "name": "@four-bytes/four-opencode-brain",
  "version": "1.2.1",
  "description": "Unified brain plugin \u2014 single SQLite DB for RAG search, memory, and knowledge base with content-hash dedup and per-session LRU cache",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/four-opencode-brain.js",
  "scripts": {
    "build": "NODE_ENV=production bun run scripts/build.ts",
    "test": "bun test",
    "build:tui": "echo \"TUI built as part of main build (tsc)\"",
    "prepublishOnly": "npm run build && npm run build:tui",
    "dev": "bun run scripts/build.ts"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "four-bytes"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "1.16.2",
    "node-llama-cpp": "3.18.1",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-php": "0.24.2",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-typescript": "0.23.2",
    "web-tree-sitter": "0.26.9",
    "@opentui/core": "0.3.2",
    "@opentui/solid": "0.3.2",
    "solid-js": "1.9.13"
  },
  "devDependencies": {
    "bun-types": "1.3.14"
  },
  "exports": {
    ".": {
      "import": "./dist/four-opencode-brain.js"
    },
    "./server": {
      "import": "./dist/four-opencode-brain.js",
      "config": {
        "enabled": true
      }
    },
    "./tui": {
      "types": "./dist/four-opencode-brain-tui.d.ts",
      "import": "./dist/four-opencode-brain-tui.jsx",
      "config": {
        "enabled": true,
        "sidebar": true
      }
    }
  }
}